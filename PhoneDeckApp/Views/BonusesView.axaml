<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PhoneDeckApp.ViewModels"
             xmlns:m="using:PhoneDeckApp.Models"
             x:Class="PhoneDeckApp.Views.BonusesView"
             x:DataType="vm:BonusesViewModel">
    <StackPanel Spacing="16">
        <TextBlock Text="Бонусы" FontSize="26" FontWeight="Bold" Foreground="White"/>

        <Border Classes="card">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="Ваши бонусы:" Foreground="#8892b0" FontSize="16" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding UserBonuses}" FontSize="32" FontWeight="Bold"
                           Foreground="#64ffda" VerticalAlignment="Center"/>
                <TextBlock Text="  |  60 минут = 1 бонус" Foreground="#8892b0"
                           FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Ваши бонусы" Command="{Binding ShowBonusesCommand}"
                    Classes="navBtn" Classes.active="{Binding !ShowHistory}"/>
            <Button Content="История" Command="{Binding ShowHistoryTabCommand}"
                    Classes="navBtn" Classes.active="{Binding ShowHistory}"/>
        </StackPanel>

        <Border Classes="card" IsVisible="{Binding !ShowHistory}">
            <StackPanel Spacing="12">
                <TextBlock Text="Выберите бонус и нажмите кнопку" Foreground="#8892b0" FontSize="13"/>

                <ListBox ItemsSource="{Binding BonusOptions}"
                         SelectedItem="{Binding SelectedOption}"
                         Background="Transparent"
                         BorderThickness="0"
                         HorizontalAlignment="Stretch">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="8,4"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="vm:BonusOption">
                            <Grid ColumnDefinitions="80,*" Margin="0,4,0,4">
                                <TextBlock Grid.Column="0" Text="{Binding Cost}"
                                           FontSize="22" FontWeight="Bold" Foreground="#64ffda"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Description}"
                                           Foreground="White" VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Content="Потратить бонусы"
                        Command="{Binding SpendBonusesCommand}"
                        IsEnabled="{Binding SelectedOption, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Classes="primaryBtn" Margin="0,8,0,0"/>

                <TextBlock Text="{Binding Message}" Foreground="#64ffda" FontSize="13"
                           IsVisible="{Binding Message, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            </StackPanel>
        </Border>

        <Border Classes="card" IsVisible="{Binding ShowHistory}">
            <StackPanel Spacing="12">
                <TextBlock Text="Нет доступной истории." Foreground="#8892b0"
                           IsVisible="{Binding !History.Count}"/>
                <Grid ColumnDefinitions="50,80,*,150">
                    <TextBlock Grid.Column="0" Text="#" Foreground="#64ffda" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Бонусы" Foreground="#64ffda" FontWeight="Bold"/>
                    <TextBlock Grid.Column="2" Text="Описание" Foreground="#64ffda" FontWeight="Bold"/>
                    <TextBlock Grid.Column="3" Text="Дата" Foreground="#64ffda" FontWeight="Bold"/>
                </Grid>
                <Rectangle Height="1" Fill="#0f3460"/>
                <ItemsControl ItemsSource="{Binding History}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="m:BonusHistoryItem">
                            <Grid ColumnDefinitions="50,80,*,150" Margin="0,4,0,4">
                                <TextBlock Grid.Column="0" Text="{Binding Code}" Foreground="#8892b0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Amount}" Foreground="#ff6b6b"/>
                                <TextBlock Grid.Column="2" Text="{Binding Description}"
                                           Foreground="White" TextWrapping="Wrap"/>
                                <TextBlock Grid.Column="3" Text="{Binding Date}" Foreground="#8892b0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>